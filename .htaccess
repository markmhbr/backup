# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/smaknisc/public_html/simak_new"
PassengerBaseURI "/"
PassengerNodejs "/home/smaknisc/nodevenv/public_html/simak_new/24/bin/node"
PassengerAppType node
PassengerStartupFile server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# Mencegah Apache otomatis menyajikan index.html dari root proyek (yang merupakan file development Vite)
DirectoryIndex disabled

RewriteEngine On
RewriteBase /

# 1. Root URL & index.html: langsung arahkan ke dist/index.html (bypass root index.html development Vite)
RewriteRule ^(index\.html)?$ dist/index.html [L]

# 2. Jika request mengarah ke file nyata, jangan di-rewrite (langsung serve)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. API: Semua request ke api.php (termasuk sub-path seperti /api.php/auth/login) diarahkan ke dist/api.php
RewriteRule ^api\.php(/.*)?$ dist/api.php$1 [L,QSA]

# 3. Jika file yang dicari ada di dalam folder /dist/, serve dari /dist/
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f
RewriteRule ^(.*)$ dist/$1 [L]

# 4. SPA Fallback: Semua request lainnya ke dist/index.html agar React Router yang menangani
RewriteRule ^(.*)$ dist/index.html [L]

<IfModule mod_headers.c>
    # Mencegah MIME-sniffing / browser menebak jenis file
    Header always set X-Content-Type-Options "nosniff"
    
    # Mencegah web dimasukkan ke dalam iframe situs lain (Anti-Clickjacking)
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Melindungi informasi rujukan link (Privacy)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Kebijakan Keamanan Konten Dasar (Mencegah XSS)
    Header always set Content-Security-Policy "default-src 'self' https: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: data:; style-src 'self' 'unsafe-inline' https:; font-src 'self' data: https:; img-src 'self' data: https:;"
</IfModule>
